{
  "manifest_version": 3,
  "name": "Date Autofill",
  "version": "1.0",
  "description": "Автоматическое заполнение дат из буфера обмена",
  "permissions": ["clipboardRead", "scripting", "tabs"],
  "host_permissions": ["https://beer.crpt.ru/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Вставить даты"
  }
}
