{
  "manifest_version": 3,
  "name": "DocsAutofill",
  "version": "3.0",
  "description": "Автоматическое заполнение документов для честного знака",
  "permissions": ["clipboardRead"],
  "content_scripts": [
    {
      "matches": [
        "https://beer.crpt.ru/requests/connect-tap/create*"
      ],
      "js": [
        "config.js",
        "libs/xlsx.full.min.js",
        "utils/notifications.js",
        "utils/react.js",
        "utils/clipboard.js",
        "utils/buttons.js",
        "utils/init_message.js",
        "pages/beer.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://milk.crpt.ru/*"
      ],
      "js": [
        "config.js",
        "utils/notifications.js",
        "utils/react.js",
        "utils/clipboard.js",
        "utils/buttons.js",
        "utils/init_message.js",
        "pages/cheese.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
